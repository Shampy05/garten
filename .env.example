VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. Google Books search (Library tab) works keyless at low volume;
# set a key to raise the request quota.
VITE_GOOGLE_BOOKS_KEY=

# Camera word mining ("Scan a page") OCR is proxied through the
# supabase/functions/ocr-page edge function — its Google Cloud Vision key is
# a server-side function secret, NOT a client env var. Do not add a
# VITE_GOOGLE_VISION_KEY here; it would ship the billable key to every
# browser. Set it with:
#   supabase secrets set GOOGLE_VISION_API_KEY=<key>
#   supabase functions deploy ocr-page
